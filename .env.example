# ══════════════════════════════════════════════════════════
# ScholarMind — Environment Configuration
# ══════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys below
# 3. Run:            streamlit run app.py

# ── LLM Provider ─────────────────────────────────────────
# "groq"   = FREE  →  get key at https://console.groq.com
# "openai" = Paid  →  get key at https://platform.openai.com
LLM_PROVIDER=groq

# ── Groq API Key (FREE) ───────────────────────────────────
# Sign up at console.groq.com → API Keys → Create Key
# Key starts with: gsk_
GROQ_API_KEY=gsk_your_groq_key_here

# ── OpenAI API Key (optional) ─────────────────────────────
# Only needed if LLM_PROVIDER=openai OR for better embeddings
OPENAI_API_KEY=

# ── Model selection ───────────────────────────────────────
# Groq free tier (RECOMMENDED — 250K TPM, no rate limit issues):
#   llama-3.1-8b-instant
# Groq higher quality (12K TPM — may rate-limit with 6 agents):
#   llama-3.3-70b-versatile
# OpenAI:
#   gpt-4o-mini
MODEL_NAME=llama-3.1-8b-instant
