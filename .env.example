# ============================================================
#  PaperMind — Katz School AI Research Assistant
#  Copy this file to .env and fill in your keys
# ============================================================

# ── Choose your LLM provider ─────────────────────────────────
# "groq"   = FREE — get key at https://console.groq.com
# "openai" = Paid — get key at https://platform.openai.com
LLM_PROVIDER=groq

# ── Groq API Key (FREE) ──────────────────────────────────────
# Sign up at https://console.groq.com (no credit card needed)
# Key starts with gsk_
GROQ_API_KEY=gsk_your_key_here

# ── OpenAI API Key (optional) ────────────────────────────────
# Used for: better KatzBot embeddings (text-embedding-3-small)
# If left blank → free HuggingFace embeddings used instead
# Key starts with sk-
OPENAI_API_KEY=

# ── Model Selection ───────────────────────────────────────────
# Groq production models (April 2026):
#   llama-3.3-70b-versatile               ← RECOMMENDED (best quality, free)
#   llama-3.1-8b-instant                  ← fastest, 14,400 req/day
#   openai/gpt-oss-120b                   ← GPT-class 120B on Groq
#   openai/gpt-oss-20b                    ← GPT-class fast on Groq
#   meta-llama/llama-4-scout-17b-16e-instruct  ← Llama 4, vision support
#   qwen/qwen3-32b                        ← strong reasoning
#
# OpenAI models:
#   gpt-4o-mini    ← cheap, fast (~$0.025/run)
#   gpt-4o         ← best quality
MODEL_NAME=llama-3.3-70b-versatile

# ── Semantic Scholar (FREE — no key needed) ───────────────────
# 200M+ academic papers, completely free for basic use
SEMANTIC_SCHOLAR_API_KEY=
